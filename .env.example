# ============================================
# AI CREATIVE ENGINE - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_creative_dev"
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_creative_dev

# ============================================
# BACKEND SERVER
# ============================================
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
API_SECRET=dev-secret-key-change-in-production

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME="AI Creative Engine"
NEXT_PUBLIC_VERSION=0.1.0

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRY=7d

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# AWS S3 (File Storage)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=ai-creative-engine-dev
AWS_S3_URL=https://your-bucket.s3.amazonaws.com

# ============================================
# AI APIS
# ============================================
# OpenAI (for DALL-E 3)
OPENAI_API_KEY=sk-your-openai-api-key

# Stable Diffusion (via Replicate or Stability API)
REPLICATE_API_TOKEN=your-replicate-token
STABILITY_API_KEY=your-stability-api-key

# BRIA Background Removal
BRIA_API_KEY=your-bria-api-key
BRIA_API_URL=https://api.bria.ai

# ============================================
# EMAIL SERVICE
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDER_EMAIL=noreply@aicreative.engine
SENDER_NAME=AI Creative Engine

# ============================================
# MONITORING & ANALYTICS
# ============================================
# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# Mixpanel (Product Analytics)
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# DataDog (APM)
DATADOG_API_KEY=your-datadog-api-key

# ============================================
# REDIS (Cache & Job Queue)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# STRIPE (Payments)
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# DEVELOPMENT FLAGS
# ============================================
DEBUG=ai-creative:*
LOG_LEVEL=debug
MOCK_AI_RESPONSES=false

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_WHITE_LABEL=true
FEATURE_BATCH_PROCESSING=true
FEATURE_AI_MODELS=false
FEATURE_PERFORMANCE_PREDICTION=false
